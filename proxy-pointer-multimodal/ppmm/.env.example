# --- Required ---------------------------------------------------------------
# Your Google Gemini API key (from https://aistudio.google.com/apikey)
GOOGLE_API_KEY="gemini key here"
# GEMINI_API_KEY is also accepted as an alias.

# --- Optional overrides (sensible defaults shown) ---------------------------
# PP_GEN_MODEL=gemini-3.1-flash-lite      # generation + vision model
# PP_EMBED_MODEL=gemini-embedding-001     # embedding model
# PP_EMBED_DIM=1536                       # embedding dimensionality
# PP_RECALL_K=200                         # broad vector recall
# PP_CANDIDATE_K=50                       # unique candidates re-ranked
# PP_FINALIST_K=5                         # sections loaded for synthesis
# PP_DATA_DIR=./data                      # where everything is stored








